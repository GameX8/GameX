<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GameX</title>

<style>
body {
  margin: 0;
  font-family: Arial;
  background: #111;
  color: white;
  text-align: center;
}

header {
  background: #222;
  padding: 15px;
  font-size: 24px;
}

.container {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
  padding: 20px;
}

.card {
  background: #1e1e1e;
  padding: 15px;
  border-radius: 10px;
}

button {
  padding: 10px;
  border: none;
  border-radius: 8px;
  background: #4CAF50;
  color: white;
  cursor: pointer;
}
</style>

</head>

<body>

<header>🎮 GameX</header>

<div class="container">

  <div class="card">
    <h3>🚗 Drive Mad</h3>
    <a href="https://www.onlinegames.io/games/2023/unity2/drive-mad/index.html" target="_blank">
      <button>🎮 العب الآن</button>
    </a>
  </div>

  <div class="card">
    <h3>🏎️ Car Rush</h3>
    <a href="https://www.onlinegames.io/games/2022/unity/car-rush/index.html" target="_blank">
      <button>🎮 العب الآن</button>
    </a>
  </div>

  <div class="card">
    <h3>🧠 Puzzle</h3>
    <a href="https://www.onlinegames.io/games/2022/html5/puzzle/index.html" target="_blank">
      <button>🎮 العب الآن</button>
    </a>
  </div>

</div>

</body>
</html>
